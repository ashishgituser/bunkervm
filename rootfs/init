#!/bin/sh
# ============================================================
# BunkerVM — PID 1 Init for Firecracker MicroVM
# ============================================================
# Direct kernel boot → this runs as PID 1. No systemd.
#
# Supports two modes (auto-detected):
#   STANDALONE — Boots with llama-server + orchestrator (AI OS)
#   SANDBOX    — Boots exec_agent.py for MCP server use
#
# Mode detection:
#   1. /etc/bunkervm/mode file ("standalone" or "sandbox")
#   2. Auto-detect: model + llama-server present → standalone
#   3. Default: sandbox
# ============================================================
set -e

# ── Phase 0: Mount essential filesystems ──
mount -t proc     proc     /proc  2>/dev/null || true
mount -t sysfs    sysfs    /sys   2>/dev/null || true
mount -t devtmpfs devtmpfs /dev   2>/dev/null || true
mkdir -p /dev/pts /dev/shm /run /tmp /var/log
mount -t devpts   devpts   /dev/pts  2>/dev/null || true
mount -t tmpfs    tmpfs    /run      2>/dev/null || true
mount -t tmpfs    tmpfs    /tmp      2>/dev/null || true
mount -t tmpfs    tmpfs    /dev/shm  2>/dev/null || true

# ── Phase 1: Console + environment ──
export TERM=xterm-256color
export HOME=/root
export PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
export PYTHONDONTWRITEBYTECODE=1

hostname bunkervm
echo "bunkervm" > /proc/sys/kernel/hostname

# ── Phase 2: Kernel tuning ──
echo 1 > /proc/sys/vm/overcommit_memory 2>/dev/null || true

# ── Phase 3: Detect mode ──
BUNKERVM_DIR="/bunkervm"
MODEL_PATH="/models/qwen2.5-0.5b-instruct-q4_k_m.gguf"
LLAMA_SERVER="/usr/bin/llama-server"
LLAMA_PORT=8080
EXEC_AGENT_PORT=8080

# Explicit mode override
if [ -f /etc/bunkervm/mode ]; then
    BUNKERVM_MODE=$(cat /etc/bunkervm/mode | tr -d '[:space:]')
fi

# Auto-detect if not set
if [ -z "$BUNKERVM_MODE" ]; then
    if [ -f "$MODEL_PATH" ] && [ -f "$LLAMA_SERVER" ]; then
        BUNKERVM_MODE="standalone"
    else
        BUNKERVM_MODE="sandbox"
    fi
fi

# ── Phase 4: Network ──
ip link set lo up 2>/dev/null || true

if [ -d /sys/class/net/eth0 ]; then
    ip link set eth0 up 2>/dev/null || true

    if [ "$BUNKERVM_MODE" = "sandbox" ]; then
        # Sandbox mode: static IP only if TAP is present (--network flag).
        # Default vsock mode has no eth0, so this block only runs
        # when the user explicitly requested networking.
        ip addr add 172.16.0.2/24 dev eth0 2>/dev/null || true
        ip route add default via 172.16.0.1 2>/dev/null || true
        echo "nameserver 8.8.8.8" > /etc/resolv.conf 2>/dev/null || true
        echo "nameserver 8.8.4.4" >> /etc/resolv.conf 2>/dev/null || true
    else
        # Standalone mode: DHCP
        if command -v udhcpc >/dev/null 2>&1; then
            udhcpc -i eth0 -s /etc/udhcpc/default.script -q -n -T 3 -t 2 2>/dev/null &
        fi
    fi
fi

# ── Boot banner ──
echo ""
if [ "$BUNKERVM_MODE" = "sandbox" ]; then
    echo "  ╔══════════════════════════════════════╗"
    echo "  ║    BunkerVM • Sandbox MicroVM        ║"
    echo "  ║    Mode: MCP Sandbox                 ║"
    echo "  ╚══════════════════════════════════════╝"
else
    echo "  ╔══════════════════════════════════════╗"
    echo "  ║     BunkerVM • AI-Native MicroVM     ║"
    echo "  ║     Mode: Standalone                 ║"
    echo "  ╚══════════════════════════════════════╝"
fi
echo ""

BOOT_TIME=$(cat /proc/uptime | cut -d' ' -f1)
echo "  Kernel → init: ${BOOT_TIME}s"
echo "  Mode: $BUNKERVM_MODE"

# ================================================================
# SANDBOX MODE — Start exec agent for MCP server
# ================================================================
if [ "$BUNKERVM_MODE" = "sandbox" ]; then
    echo ""

    # Verify exec agent exists
    if [ ! -f "$BUNKERVM_DIR/exec_agent.py" ]; then
        echo "  ERROR: Missing $BUNKERVM_DIR/exec_agent.py"
        echo "  Dropping to rescue shell..."
        exec /bin/sh
    fi

    # Show connectivity info
    echo "  Transport: vsock (CID=3, port=$EXEC_AGENT_PORT)"
    if [ -d /sys/class/net/eth0 ]; then
        ETH0_IP=$(ip -4 addr show eth0 2>/dev/null | awk '/inet / {split($2, a, "/"); print a[1]}' || echo "none")
        echo "  Network: eth0 = $ETH0_IP (optional)"
    fi

    # Start exec agent (listens on both vsock + TCP localhost)
    echo "  Starting exec agent..."
    cd "$BUNKERVM_DIR"
    python3 exec_agent.py &
    AGENT_PID=$!

    # Wait for it to be ready
    echo -n "  Waiting for agent "
    for i in $(seq 1 30); do
        if ! kill -0 $AGENT_PID 2>/dev/null; then
            echo ""
            echo "  ERROR: exec_agent.py crashed!"
            exec /bin/sh
        fi
        # Quick health check via wget or curl
        if wget -q -O- "http://127.0.0.1:${EXEC_AGENT_PORT}/health" 2>/dev/null | grep -q ok; then
            READY_TIME=$(cat /proc/uptime | cut -d' ' -f1)
            echo ""
            echo "  ✓ Sandbox ready in ${READY_TIME}s (PID $AGENT_PID)"
            echo "  Host communicates via vsock (no network needed)"
            break
        fi
        echo -n "."
        sleep 0.2
    done
    echo ""
    echo "  Waiting for MCP server connection..."
    echo ""

    # Keep PID 1 alive — wait for agent
    wait $AGENT_PID 2>/dev/null || true

    echo ""
    echo "  Exec agent exited. Rescue shell:"
    exec /bin/sh
fi

# ================================================================
# STANDALONE MODE — Start llama-server + orchestrator
# ================================================================

# ── Verify critical files ──
BOOT_OK=1
for f in "$LLAMA_SERVER" "$MODEL_PATH" "$BUNKERVM_DIR/orchestrator.py"; do
    if [ ! -f "$f" ]; then
        echo "  ERROR: Missing $f"
        BOOT_OK=0
    fi
done

if [ "$BOOT_OK" = "0" ]; then
    echo ""
    echo "  Boot failed: required files missing."
    echo "  Dropping to rescue shell..."
    exec /bin/sh
fi

# ── Start llama-server ──
echo "  Starting inference engine..."
echo "  Model: $(ls -lh $MODEL_PATH | awk '{print $5}') — loading..."
"$LLAMA_SERVER" \
    --model "$MODEL_PATH" \
    --host 127.0.0.1 \
    --port "$LLAMA_PORT" \
    --threads 2 \
    --ctx-size 2048 \
    --batch-size 256 \
    --no-mmap \
    > /var/log/llama-server.log 2>&1 &

LLAMA_PID=$!
echo "  Inference PID: $LLAMA_PID"

# Wait for llama-server to be ready (show progress)
echo -n "  Loading model "
for i in $(seq 1 120); do
    # Check if process died
    if ! kill -0 $LLAMA_PID 2>/dev/null; then
        echo ""
        echo "  ERROR: llama-server crashed!"
        echo "  Log output:"
        cat /var/log/llama-server.log 2>/dev/null
        echo ""
        echo "  Dropping to rescue shell..."
        exec /bin/sh
    fi
    # Check health endpoint
    if wget -q -O- http://127.0.0.1:${LLAMA_PORT}/health 2>/dev/null | grep -q ok; then
        READY_TIME=$(cat /proc/uptime | cut -d' ' -f1)
        echo ""
        echo "  ✓ Engine ready in ${READY_TIME}s"
        break
    fi
    echo -n "."
    sleep 1
done
echo ""

# ── Launch BunkerVM Agent ──
export LLAMA_URL="http://127.0.0.1:${LLAMA_PORT}"
export BUNKERVM_DIR

cd "$BUNKERVM_DIR"

if command -v python3 >/dev/null 2>&1; then
    python3 orchestrator.py
    AGENT_EXIT=$?
else
    echo "  ERROR: Python3 not found!"
    AGENT_EXIT=1
fi

# ── PID 1 must never exit — drop to rescue shell ──
echo ""
echo "  Agent exited ($AGENT_EXIT). Rescue shell:"
exec /bin/sh
