build/rootfs.ext4
build/vmlinux
build/bin/
build/work/
build/*.iso

# Model weights
models/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
*.egg

# Secrets
.env
.env.*

# Logs
*.log
.bunkervm/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Build / Package
*.tar.gz
*.whl
*.dist-info/
build/lib/
build/bdist*/

# Desktop app build artifacts
desktop/dist/
desktop/build/BunkerDesktop/

# Installer output
installer/windows/Output/
